# Gov.br credentials
GOVBR_CPF=00000000000
GOVBR_SENHA=your_password_here

# SMTP email configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_TO=recipient@example.com

# WhatsApp notification
WHATSAPP_NUMBER=5511999999999

# Job scheduling
JOB_DIA_FECHAMENTO=7
CRON_SCHEDULE=0 9 7 * *

# Competency override (optional, defaults to current month/year)
COMPETENCIA_MES=
COMPETENCIA_ANO=

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
