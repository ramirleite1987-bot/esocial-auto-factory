# ===========================
# Gov.br Credentials (REQUIRED)
# ===========================
GOVBR_CPF=00000000000
GOVBR_SENHA=your_password_here

# ===========================
# eSocial API Configuration
# ===========================
# Base URL for eSocial API (default: https://login.esocial.gov.br)
ESOCIAL_BASE_URL=https://login.esocial.gov.br
# HTTP request timeout in milliseconds (default: 30000)
ESOCIAL_TIMEOUT=30000

# ===========================
# SMTP Email Notifications
# ===========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_TO=recipient@example.com

# ===========================
# WhatsApp Notifications
# ===========================
WHATSAPP_NUMBER=5511999999999

# ===========================
# Slack Notifications (optional)
# ===========================
# Incoming-webhook URL. Leave unset to disable Slack notifications.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/AAAAA/BBBBB/CCCCC
# Request timeout in ms (default: 5000)
# SLACK_TIMEOUT_MS=5000

# ===========================
# Job Scheduling
# ===========================
# Day of month to run the job (default: 7)
JOB_DIA_FECHAMENTO=7
# Full cron expression (overrides JOB_DIA_FECHAMENTO if set)
# CRON_SCHEDULE=0 9 7 * *
# Max retry attempts for API calls (default: 3)
JOB_MAX_RETRIES=3

# ===========================
# Competency Override (optional)
# ===========================
# Leave empty or set to 'auto' for auto-calculation (previous month)
COMPETENCIA_MES=
COMPETENCIA_ANO=

# ===========================
# Logging
# ===========================
LOG_LEVEL=info
LOG_DIR=./logs

# ===========================
# Health Check Server
# ===========================
# Set to 'true' to enable HTTP health check endpoint
HEALTH_ENABLED=false
# Port for health check server (default: 3000)
HEALTH_PORT=3000
